# Server
PORT=5000
NODE_ENV=development
SERVER_URL=http://localhost:5000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/raksha24x7
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=2
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_RETRY_ATTEMPTS=3
MONGODB_RETRY_DELAY_MS=2000

# JWT
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=replace_with_separate_strong_admin_secret
ADMIN_JWT_EXPIRES_IN=8h
JWT_ISSUER=raksha24x7-api
JWT_AUDIENCE=raksha24x7-users
ADMIN_JWT_ISSUER=raksha24x7-admin
ADMIN_JWT_AUDIENCE=raksha24x7-admins
COOKIE_SECRET=replace_with_signed_cookie_secret
SESSION_SECRET=replace_with_session_secret
BCRYPT_ROUNDS=12

# Logging and monitoring
LOG_LEVEL=debug
LOG_DIR=server/logs
SLOW_REQUEST_THRESHOLD_MS=1000
MEMORY_WARNING_RATIO=0.85
TRUST_PROXY=1
UPLOAD_LIMIT=5mb
UPLOAD_FILE_SIZE_BYTES=2097152
URLENCODED_LIMIT=1mb
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000

# Client
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://your-production-domain.com
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_DEV_REDIRECT_URI=http://localhost:5173/auth/google/callback
GOOGLE_PROD_REDIRECT_URI=https://your-production-domain.com/auth/google/callback
GOOGLE_AUTHORIZED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# Maps
MAP_PROVIDER=openstreetmap
OPENSTREETMAP_ENDPOINT=https://nominatim.openstreetmap.org

# Email service
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@raksha24x7.com
EMAIL_FROM_NAME=Raksha24x7
RESEND_API_KEY=your_resend_api_key
SUPPORT_EMAIL=support@raksha24x7.com

# Optional SMTP fallback / future provider support
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# SMTP_* aliases are also accepted by environment validation
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
EMAIL_CONNECTION_TIMEOUT_MS=10000
EMAIL_GREETING_TIMEOUT_MS=10000
EMAIL_SOCKET_TIMEOUT_MS=15000
EMAIL_VERIFY_ON_STARTUP=false

# Firebase Admin SDK for server-side FCM delivery
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key\n-----END PRIVATE KEY-----\n"
