VITE_APP_ENV=production
VITE_APP_VERSION=1.0.0
VITE_SERVER_URL=https://api.your-domain.com
VITE_API_PROXY_TARGET=https://api.your-domain.com
VITE_BUILD_SOURCEMAP=false

VITE_GOOGLE_MAPS_API_KEY=your_production_google_maps_api_key

VITE_FIREBASE_API_KEY=your_production_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_optional
VITE_FIREBASE_VAPID_KEY=your_web_push_certificate_key
