PORT=5000
NODE_ENV=production
SERVER_URL=https://api.your-domain.com
CLIENT_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
TRUST_PROXY=1

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/raksha24x7?retryWrites=true&w=majority
MONGODB_MAX_POOL_SIZE=30
MONGODB_MIN_POOL_SIZE=5
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_RETRY_ATTEMPTS=5
MONGODB_RETRY_DELAY_MS=3000

JWT_SECRET=replace_with_64_plus_character_random_user_secret
ADMIN_JWT_SECRET=replace_with_64_plus_character_random_admin_secret
JWT_EXPIRES_IN=7d
ADMIN_JWT_EXPIRES_IN=8h
JWT_ISSUER=raksha24x7-api
JWT_AUDIENCE=raksha24x7-users
ADMIN_JWT_ISSUER=raksha24x7-admin
ADMIN_JWT_AUDIENCE=raksha24x7-admins
COOKIE_SECRET=replace_with_64_plus_character_cookie_secret
SESSION_SECRET=replace_with_64_plus_character_session_secret
BCRYPT_ROUNDS=12

GOOGLE_CLIENT_ID=your_production_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_production_google_oauth_client_secret
GOOGLE_PROD_REDIRECT_URI=https://your-domain.com/auth/google/callback
GOOGLE_AUTHORIZED_ORIGINS=https://your-domain.com,https://www.your-domain.com

EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@your-domain.com
EMAIL_FROM_NAME=Raksha24x7
RESEND_API_KEY=your_production_resend_api_key
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_CONNECTION_TIMEOUT_MS=10000
EMAIL_GREETING_TIMEOUT_MS=10000
EMAIL_SOCKET_TIMEOUT_MS=15000
EMAIL_VERIFY_ON_STARTUP=true

MAP_PROVIDER=openstreetmap
OPENSTREETMAP_ENDPOINT=https://nominatim.openstreetmap.org
LOG_LEVEL=info
LOG_DIR=server/logs
SLOW_REQUEST_THRESHOLD_MS=1000
MEMORY_WARNING_RATIO=0.85
UPLOAD_LIMIT=5mb
UPLOAD_FILE_SIZE_BYTES=2097152
URLENCODED_LIMIT=1mb
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=300

BACKUP_ENABLED=true
BACKUP_DIRECTORY=server/backups
BACKUP_RETENTION_DAYS=30
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4
BACKUP_KEEP_MONTHLY=12
BACKUP_SCHEDULE=daily
BACKUP_PROVIDER=atlas
BACKUP_COMPRESSION=true
BACKUP_ENCRYPTION=false
BACKUP_ENCRYPTION_KEY=
BACKUP_MAX_COLLECTION_EXPORT=0

FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_firebase_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
