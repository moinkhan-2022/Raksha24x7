PORT=5000
NODE_ENV=production
SERVER_URL=https://api.your-domain.com
CLIENT_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com
TRUST_PROXY=1

MONGODB_URI=your_mongodb_connection_string
MONGODB_MAX_POOL_SIZE=30
MONGODB_MIN_POOL_SIZE=5
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_RETRY_ATTEMPTS=5
MONGODB_RETRY_DELAY_MS=3000

JWT_SECRET=your_jwt_secret
ADMIN_JWT_SECRET=your_admin_jwt_secret
JWT_EXPIRES_IN=7d
ADMIN_JWT_EXPIRES_IN=8h
JWT_ISSUER=raksha24x7-api
JWT_AUDIENCE=raksha24x7-users
ADMIN_JWT_ISSUER=raksha24x7-admin
ADMIN_JWT_AUDIENCE=raksha24x7-admins
COOKIE_SECRET=your_cookie_secret
SESSION_SECRET=your_session_secret
BCRYPT_ROUNDS=12

GOOGLE_CLIENT_ID=your_production_google_client_id
GOOGLE_CLIENT_SECRET=your_production_google_client_secret
GOOGLE_PROD_REDIRECT_URI=https://your-domain.com/auth/google/callback
GOOGLE_AUTHORIZED_ORIGINS=https://your-domain.com

EMAIL_PROVIDER=smtp
EMAIL_FROM=Raksha24x7 <your_email@gmail.com>
EMAIL_FROM_NAME=Raksha24x7
RESEND_API_KEY=your_resend_api_key_optional
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_CONNECTION_TIMEOUT_MS=10000
EMAIL_GREETING_TIMEOUT_MS=10000
EMAIL_SOCKET_TIMEOUT_MS=15000
EMAIL_VERIFY_ON_STARTUP=true

MAP_PROVIDER=openstreetmap
OPENSTREETMAP_ENDPOINT=https://nominatim.openstreetmap.org
LOG_LEVEL=info
LOG_DIR=server/logs
SLOW_REQUEST_THRESHOLD_MS=1000
MEMORY_WARNING_RATIO=0.85
UPLOAD_LIMIT=5mb
UPLOAD_FILE_SIZE_BYTES=2097152
URLENCODED_LIMIT=1mb
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=300

BACKUP_ENABLED=true
BACKUP_DIRECTORY=server/backups
BACKUP_RETENTION_DAYS=30
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4
BACKUP_KEEP_MONTHLY=12
BACKUP_SCHEDULE=daily
BACKUP_PROVIDER=atlas
BACKUP_COMPRESSION=true
BACKUP_ENCRYPTION=false
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key_optional
BACKUP_MAX_COLLECTION_EXPORT=0

FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key
